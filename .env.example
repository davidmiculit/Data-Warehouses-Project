# ---- Cassandra ----
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=acme_dwh
CASSANDRA_REPLICATION_FACTOR=1
# Optional auth (leave blank for the default docker-compose dev cluster)
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

# ---- REST API ----
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_PATH=/api/v1
# Max business-date span (days) the /data endpoint and MCP will serve in one call
MAX_DATA_RANGE_DAYS=370

# ---- Ingestion ----
INGEST_PROVIDER=bitfinex
NDL_API_KEY=

# ---- MCP / LLM ----
MCP_API_BASE_URL=http://127.0.0.1:8000/api/v1
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
